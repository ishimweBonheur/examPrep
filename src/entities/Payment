{
  "name": "Payment",
  "type": "object",
  "properties": {
    "student_id": {
      "type": "string"
    },
    "subscription_id": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "plan_name": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "default": "USD"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "stripe",
        "mobile_money",
        "manual"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "completed",
        "failed",
        "refunded"
      ],
      "default": "pending"
    },
    "transaction_ref": {
      "type": "string"
    },
    "phone_number": {
      "type": "string",
      "description": "For mobile money payments"
    },
    "billing_cycle": {
      "type": "string",
      "enum": [
        "monthly",
        "yearly"
      ]
    }
  },
  "required": [
    "student_id",
    "amount",
    "payment_method"
  ]
}