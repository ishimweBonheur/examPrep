{
  "name": "Document",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Document title"
    },
    "description": {
      "type": "string",
      "description": "Brief description"
    },
    "subject_id": {
      "type": "string",
      "description": "Reference to subject"
    },
    "subject_name": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "year": {
      "type": "number",
      "description": "Exam year (e.g., 2022)"
    },
    "category": {
      "type": "string",
      "enum": [
        "past_paper",
        "solutions",
        "study_notes",
        "revision_guide"
      ],
      "description": "Document category"
    },
    "file_url": {
      "type": "string",
      "description": "URL of the uploaded document"
    },
    "solution_url": {
      "type": "string",
      "description": "URL of the solution file (if separate)"
    },
    "file_type": {
      "type": "string",
      "enum": [
        "pdf",
        "image",
        "docx",
        "other"
      ],
      "description": "File format type"
    },
    "level": {
      "type": "string",
      "enum": [
        "S1",
        "S2",
        "S3",
        "S6"
      ],
      "default": "S3"
    },
    "downloads_count": {
      "type": "number",
      "default": 0
    },
    "views_count": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "title",
    "subject_id",
    "category",
    "file_url"
  ]
}