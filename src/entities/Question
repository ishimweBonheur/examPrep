{
  "name": "Question",
  "type": "object",
  "properties": {
    "subject_id": {
      "type": "string",
      "description": "Reference to subject"
    },
    "topic": {
      "type": "string",
      "description": "Topic within the subject"
    },
    "level": {
      "type": "string",
      "enum": [
        "S1",
        "S2",
        "S3",
        "S6"
      ],
      "default": "S3"
    },
    "question_text": {
      "type": "string",
      "description": "The question text"
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      }
    },
    "correct_answer": {
      "type": "string",
      "description": "The correct option label"
    },
    "explanation": {
      "type": "string",
      "description": "Explanation of the answer"
    },
    "source": {
      "type": "string",
      "enum": [
        "national_exam",
        "textbook",
        "ai_generated"
      ],
      "description": "Source of the question"
    },
    "year": {
      "type": "number",
      "description": "Year of the national exam if applicable"
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "easy",
        "medium",
        "hard"
      ],
      "default": "medium"
    }
  },
  "required": [
    "subject_id",
    "question_text",
    "correct_answer"
  ]
}