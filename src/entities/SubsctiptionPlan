{
  "name": "SubscriptionPlan",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Plan name"
    },
    "description": {
      "type": "string"
    },
    "price_monthly": {
      "type": "number",
      "description": "Monthly price in USD"
    },
    "price_yearly": {
      "type": "number",
      "description": "Yearly price in USD (discounted)"
    },
    "currency": {
      "type": "string",
      "default": "USD"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "number",
      "default": 0
    },
    "recommended": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "name",
    "price_monthly"
  ]
}