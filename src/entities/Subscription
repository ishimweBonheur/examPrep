{
  "name": "Subscription",
  "type": "object",
  "properties": {
    "student_id": {
      "type": "string",
      "description": "Reference to user"
    },
    "plan_id": {
      "type": "string",
      "description": "Reference to subscription plan"
    },
    "plan_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "trial",
        "active",
        "cancelled",
        "expired"
      ],
      "default": "trial",
      "description": "Current subscription status"
    },
    "trial_start_date": {
      "type": "string",
      "format": "date"
    },
    "trial_end_date": {
      "type": "string",
      "format": "date"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "billing_cycle": {
      "type": "string",
      "enum": [
        "monthly",
        "yearly"
      ]
    },
    "amount_paid": {
      "type": "number"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "stripe",
        "mobile_money",
        "manual"
      ]
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "failed"
      ],
      "default": "pending"
    },
    "auto_renew": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "student_id"
  ]
}