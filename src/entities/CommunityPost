{
  "name": "CommunityPost",
  "type": "object",
  "properties": {
    "author_id": {
      "type": "string",
      "description": "Reference to user who posted"
    },
    "author_name": {
      "type": "string"
    },
    "subject": {
      "type": "string",
      "description": "Subject area"
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "is_teacher_only": {
      "type": "boolean",
      "default": false,
      "description": "If true, only teachers/admins can see"
    },
    "replies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "author_id": {
            "type": "string"
          },
          "author_name": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "is_teacher": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string"
          }
        }
      }
    },
    "likes": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "author_id",
    "title",
    "content"
  ]
}